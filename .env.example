# Copy to .env.local and fill in.
#
# Local development (recommended): run `npx supabase start` and copy the values
# it prints ("API URL", "anon key", "service_role key").
#
# Production: use your hosted Supabase project's URL and keys
# (Project Settings → API).

# Required by the app (browser + server)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required only by `npm run seed` and integration tests. NEVER expose to the
# browser and never commit real values.
SUPABASE_SERVICE_ROLE_KEY=

# AI features (smart add-paper processing, reading breakdowns, synthesis
# drafts). Server-side only — the key never reaches the browser. The app works
# without it; AI features simply stay disabled.
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_MODEL=gpt-5-mini
# OPENAI_BASE_URL=            # tests point this at a local mock
# AI_MAX_RUNS_PER_HOUR=10     # processing + Q&A rate limit per user
# QA_MAX_OUTPUT_TOKENS=1200   # reading-mode Q&A answer cap
# FORMULA_OCR_MODEL=gpt-5.4-nano  # low-cost equation screenshot -> LaTeX OCR

# Research Radar fetches paper metadata from the arXiv API. Override only for
# tests (both suites point this at the local mock); leave unset in normal use.
# ARXIV_BASE_URL=

# Account the seed script creates/uses (local dev convenience).
SEED_EMAIL=researcher@example.com
SEED_PASSWORD=research-atlas-dev
